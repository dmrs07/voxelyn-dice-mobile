{
  "name": "voxelyn-dice-mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "assets:build": "node scripts/build-pixel-assets.mjs",
    "assets:check": "node scripts/check-pixel-assets.mjs",
    "qa:pixel": "npm run assets:build && npm run assets:check && npm run typecheck && npm run build",
    "inspect:voxelyn": "node scripts/inspect-voxelyn.mjs",
    "inspect:animation": "node scripts/inspect-animation.mjs",
    "inspect:all": "npm run inspect:voxelyn && npm run inspect:animation",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/preferences": "^6.0.3",
    "@voxelyn/animation": "^0.1.1",
    "@voxelyn/core": "^0.1.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/cli": "^6.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0"
  }
}
